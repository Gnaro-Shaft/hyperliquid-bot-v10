# === V10 — variables d'environnement ===

# MongoDB (dépendance dure : collecte + signaux passent par Mongo)
MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net
MONGO_DB=bot_hyperliquid_v10

# Hyperliquid (trading tiny-size)
HYPERLIQUID_API_KEY=0x...     # wallet address
HYPERLIQUID_API_SECRET=0x...  # private key

# Telegram (alertes santé + trades)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Modes
PAPER_MODE=false
PAPER_START_BALANCE=1000
DEBUG=true
REGIME_ADAPTIVE=true

# Collecte baleines
WHALE_ENABLED=true
WHALE_TOP_N=30
WHALE_POLL_INTERVAL=180
# Adresses forcées si le leaderboard (non officiel) est indisponible :
# WHALE_ADDRESSES=0xabc...,0xdef...

# Export
# PARQUET_DIR=data/parquet
# LARGE_TRADE_USD=25000
